rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Deny Firestore access until authenticated product flows are implemented.
    // If Firestore reads/writes fail with permission-denied, this is intentional:
    // add collection-specific rules with tests before deploying data features.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
